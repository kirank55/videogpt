# OpenRouter API Key (retrieve yours from https://openrouter.ai/)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Default LLM model identifier. E.g., deepseek/deepseek-v4-flash, moonshotai/kimi-k2.5 from OpenRouter.
DEFAULT_MODEL=deepseek/deepseek-v4-flash

# Directory for bulk generation scripts output (only needed for CLI scripts: runBulkGeneration, collectBulkProjects).
# BRAIN_DIR=C:\path\to\your\output\directory
